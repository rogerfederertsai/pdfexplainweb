# 複製為 .env 後填入；啟動 uvicorn 前請載入環境變數（或於系統環境變數設定）
# Windows PowerShell 範例： Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { Set-Item "env:$($matches[1])" $matches[2].Trim() } }

# Web 登入（公開給他人使用前務必改成強密碼）
WEB_LOGIN_USERNAME=roger
WEB_LOGIN_PASSWORD=0000

# 若對外網址為 HTTPS（例如 Cloudflare Tunnel），設為 1 以啟用 Secure Cookie
WEB_COOKIE_SECURE=0
